<Page x:Class="MCServerLauncher.WPF.InstanceConsole.View.Pages.ComponentManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:i18n="clr-namespace:MCServerLauncher.WPF.Modules"
      xmlns:ge="clr-namespace:MCServerLauncher.WPF.View.Components.Generic"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ComponentManagerPage"
      AllowDrop="True"
      Drop="Page_Drop"
      DragOver="Page_DragOver">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Margin="25,15,25,25" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SupportsComponents}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <Button Command="{Binding AddComponentCommand}" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Add}" FontSize="14" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding AddComponentText}" />
                </StackPanel>
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="IsEnabled" Value="True" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SupportsComponents}" Value="False">
                                <Setter Property="IsEnabled" Value="False" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsCurrentTabSupported}" Value="False">
                                <Setter Property="IsEnabled" Value="False" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Command="{Binding RefreshCommand}" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Refresh}" FontSize="14" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding [Refresh], Source={x:Static i18n:Lang.Tr}}" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Tab Control -->
        <TabControl Grid.Row="1"
                    FontSize="24"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <TabControl.Style>
                <Style TargetType="TabControl" BasedOn="{StaticResource TabControlPivotStyle}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SupportsComponents}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Style>
            <!-- Mods Tab -->
            <TabItem Header="{Binding [Mods], Source={x:Static i18n:Lang.Tr}}"
                     IsEnabled="{Binding HasMods}">
                <Grid>
                <ui:ListView Margin="0,15,0,0"
                             ItemsSource="{Binding Mods}">
                    <ui:ListView.Style>
                        <Style TargetType="ui:ListView">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCurrentTabEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:ListView.Style>
                    <ui:ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="40" Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Enabled/disabled indicator -->
                                <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,10,0"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#4CAF50" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                    <Setter Property="Fill" Value="#9E9E9E" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <!-- Title + Description -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Border Margin="8,0,0,0" Padding="6,1" CornerRadius="8"
                                                Background="#FFD83B01"
                                                Visibility="{Binding IsClientSideOnly, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding [ComponentManager_ClientSideBadge], Source={x:Static i18n:Lang.Tr}}" FontSize="10" Foreground="White" FontWeight="SemiBold" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <!-- More Button -->
                                <ui:DropDownButton Grid.Column="2" Height="30" VerticalAlignment="Center">
                                    <ui:DropDownButton.Content>
                                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.More}" FontSize="14" />
                                    </ui:DropDownButton.Content>
                                    <ui:DropDownButton.Flyout>
                                        <ui:MenuFlyout Placement="Bottom">
                                            <MenuItem Command="{Binding DataContext.ToggleEnabledCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                        <Setter Property="Header"
                                                                Value="{Binding [ComponentManager_Disable], Source={x:Static i18n:Lang.Tr}}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                <Setter Property="Header"
                                                                        Value="{Binding [ComponentManager_Enable], Source={x:Static i18n:Lang.Tr}}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Checkbox}" FontSize="16" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{Binding [ComponentManager_Locate], Source={x:Static i18n:Lang.Tr}}"
                                                      Command="{Binding DataContext.LocateCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.OpenFile}" FontSize="16" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="{Binding [Delete], Source={x:Static i18n:Lang.Tr}}"
                                                      Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Delete}" FontSize="16" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ui:MenuFlyout>
                                    </ui:DropDownButton.Flyout>
                                </ui:DropDownButton>
                            </Grid>
                        </DataTemplate>
                    </ui:ListView.ItemTemplate>
                </ui:ListView>
                <ge:StopTipLayer Symbol="📦"
                                 StopTip="{Binding [NothingHere], Source={x:Static i18n:Lang.Tr}}"
                                 StopDescription="{Binding [ComponentManager_EmptyMods], Source={x:Static i18n:Lang.Tr}}"
                                 ButtonText="{Binding [ComponentManager_AddMod], Source={x:Static i18n:Lang.Tr}}"
                                 ButtonIcon="{x:Static ui:SegoeFluentIcons.AddTo}"
                                 ButtonCommand="{Binding AddComponentCommand}">
                    <ge:StopTipLayer.Style>
                        <Style TargetType="ge:StopTipLayer">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCurrentTabEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ge:StopTipLayer.Style>
                </ge:StopTipLayer>
                </Grid>
            </TabItem>

            <!-- Plugins Tab -->
            <TabItem Header="{Binding [Plugins], Source={x:Static i18n:Lang.Tr}}"
                     IsEnabled="{Binding HasPlugins}">
                <Grid>
                <ui:ListView Margin="0,15,0,0"
                             ItemsSource="{Binding Plugins}">
                    <ui:ListView.Style>
                        <Style TargetType="ui:ListView">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCurrentTabEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:ListView.Style>
                    <ui:ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="40" Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,10,0"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#4CAF50" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                    <Setter Property="Fill" Value="#9E9E9E" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Border Margin="8,0,0,0" Padding="6,1" CornerRadius="8"
                                                Background="#FFD83B01"
                                                Visibility="{Binding IsClientSideOnly, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding [ComponentManager_ClientSideBadge], Source={x:Static i18n:Lang.Tr}}" FontSize="10" Foreground="White" FontWeight="SemiBold" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <ui:DropDownButton Grid.Column="2" Height="30" VerticalAlignment="Center">
                                    <ui:DropDownButton.Content>
                                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.More}" FontSize="14" />
                                    </ui:DropDownButton.Content>
                                    <ui:DropDownButton.Flyout>
                                        <ui:MenuFlyout Placement="Bottom">
                                            <MenuItem Command="{Binding DataContext.ToggleEnabledCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                        <Setter Property="Header"
                                                                Value="{Binding [ComponentManager_Disable], Source={x:Static i18n:Lang.Tr}}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                <Setter Property="Header"
                                                                        Value="{Binding [ComponentManager_Enable], Source={x:Static i18n:Lang.Tr}}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Checkbox}" FontSize="16" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{Binding [ComponentManager_Locate], Source={x:Static i18n:Lang.Tr}}"
                                                      Command="{Binding DataContext.LocateCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.OpenFile}" FontSize="16" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="{Binding [Delete], Source={x:Static i18n:Lang.Tr}}"
                                                      Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Delete}" FontSize="16" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ui:MenuFlyout>
                                    </ui:DropDownButton.Flyout>
                                </ui:DropDownButton>
                            </Grid>
                        </DataTemplate>
                    </ui:ListView.ItemTemplate>
                </ui:ListView>
                <ge:StopTipLayer Symbol="🧩"
                                 StopTip="{Binding [NothingHere], Source={x:Static i18n:Lang.Tr}}"
                                 StopDescription="{Binding [ComponentManager_EmptyPlugins], Source={x:Static i18n:Lang.Tr}}"
                                 ButtonText="{Binding [ComponentManager_AddPlugin], Source={x:Static i18n:Lang.Tr}}"
                                 ButtonIcon="{x:Static ui:SegoeFluentIcons.AddTo}"
                                 ButtonCommand="{Binding AddComponentCommand}">
                    <ge:StopTipLayer.Style>
                        <Style TargetType="ge:StopTipLayer">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCurrentTabEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ge:StopTipLayer.Style>
                </ge:StopTipLayer>
                </Grid>
            </TabItem>
        </TabControl>

        <ge:StopTipLayer Grid.Row="1"
                         Symbol="🧰"
                         StopTip="{Binding [FuncDisabled], Source={x:Static i18n:Lang.Tr}}"
                         StopDescription="{Binding [ComponentManager_Unsupported], Source={x:Static i18n:Lang.Tr}}"
                         ButtonText="{Binding [Refresh], Source={x:Static i18n:Lang.Tr}}"
                         ButtonIcon="{x:Static ui:SegoeFluentIcons.Refresh}"
                         ButtonCommand="{Binding RefreshCommand}">
            <ge:StopTipLayer.Style>
                <Style TargetType="ge:StopTipLayer">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SupportsComponents}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ge:StopTipLayer.Style>
        </ge:StopTipLayer>

        <!-- Loading overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="2"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
              Background="{DynamicResource AcrylicBackgroundFillColorDefaultBrush}">
            <ui:ProgressRing IsActive="{Binding IsLoading}"
                             Width="48" Height="48"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Page>
