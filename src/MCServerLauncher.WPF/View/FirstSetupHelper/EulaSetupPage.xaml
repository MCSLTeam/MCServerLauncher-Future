<Page x:Class="MCServerLauncher.WPF.View.FirstSetupHelper.EulaSetupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:i18n="clr-namespace:MCServerLauncher.WPF.Modules"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EulaSetupPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Margin="40,40,40,0" Grid.Row="0" Style="{StaticResource TitleTextBlock}" Text="{Binding [FirstSetup_EulaMenu], Source={x:Static i18n:Lang.Tr}}"
                   HorizontalAlignment="Left" />
        <Grid Grid.Row="1" Margin="40,20,40,0">
            <ikw:SimpleStackPanel VerticalAlignment="Center">
                <TextBlock TextTrimming="CharacterEllipsis" TextWrapping="WrapWithOverflow"
                           Style="{StaticResource BodyTextBlock}"
                           Text="{Binding [FirstSetup_EulaOnlineTip], Source={x:Static i18n:Lang.Tr}}" />
                <TextBlock Margin="0,12,0,0" TextTrimming="CharacterEllipsis" TextWrapping="WrapWithOverflow"
                           Style="{StaticResource CaptionTextBlock}"
                           Text="{Binding [FirstSetup_EulaUrlLabel], Source={x:Static i18n:Lang.Tr}}" />
                <Border Margin="0,12,0,0" Style="{StaticResource StyledBorder}" Padding="16,12">
                    <TextBlock x:Name="EulaUrlTextBlock" TextWrapping="Wrap" />
                </Border>
                <Button Margin="0,12,0,0" HorizontalAlignment="Left" Click="OpenEulaInBrowser">
                    <Button.Content>
                        <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.OpenInNewWindow}"
                                        Content="{Binding [FirstSetup_EulaOpenInBrowser], Source={x:Static i18n:Lang.Tr}}" />
                    </Button.Content>
                </Button>
            </ikw:SimpleStackPanel>
        </Grid>
        <Border Grid.Row="2" Style="{StaticResource StyledBorder}" Height="80">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" HorizontalAlignment="Left" Margin="40,0,0,0" Click="RefuseEula">
                    <Button.Content>
                        <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.Cancel}" Content="{Binding [Disagree], Source={x:Static i18n:Lang.Tr}}" />
                    </Button.Content>
                </Button>
                <Button x:Name="AcceptButton" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,40,0" Click="AcceptEula"
                        Style="{StaticResource AccentButtonStyle}">
                    <Button.Content>
                        <ui:IconAndText x:Name="AcceptButtonContent" IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.Accept}" Content="{Binding [Agree], Source={x:Static i18n:Lang.Tr}}" />
                    </Button.Content>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>
