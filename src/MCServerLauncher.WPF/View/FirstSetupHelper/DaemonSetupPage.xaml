<ui:Page x:Class="MCServerLauncher.WPF.View.FirstSetupHelper.DaemonSetupPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
         xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
         xmlns:i18n="clr-namespace:MCServerLauncher.WPF.Modules"
         xmlns:dmc="clr-namespace:MCServerLauncher.WPF.View.Components.DaemonManager"
         mc:Ignorable="d"
         d:DesignHeight="450" d:DesignWidth="800"
         Title="DaemonSetupPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ikw:SimpleStackPanel Grid.Column="0" Margin="40" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource TitleTextBlock}"
                           FontSize="38"
                           Text="{Binding [FirstSetup_ConnectDaemonMenu], Source={x:Static i18n:Lang.Tr}}"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,14,0,0"
                           Style="{StaticResource MinititleTextBlock}"
                           Text="{Binding [FirstSetup_ConnectDaemonTip], Source={x:Static i18n:Lang.Tr}}"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="WrapWithOverflow" />
            </ikw:SimpleStackPanel>

            <Grid Grid.Column="1" Margin="36" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ikw:SimpleStackPanel x:Name="LocalChoicePanel"
                                      Grid.Row="0"
                                      Spacing="12">
                    <TextBlock Style="{StaticResource SubtitleTextBlock}"
                               Text="{Binding [FirstSetup_DaemonLocalQuestion], Source={x:Static i18n:Lang.Tr}}"
                               TextWrapping="Wrap" />
                    <TextBlock Style="{StaticResource MinititleTextBlock}"
                               Text="{Binding [FirstSetup_DaemonLocalQuestionTip], Source={x:Static i18n:Lang.Tr}}"
                               TextWrapping="Wrap" />
                    <Button HorizontalAlignment="Stretch"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="UseLocalDaemon">
                        <Button.Content>
                            <ui:IconAndText IsTabStop="False"
                                            Icon="{x:Static ui:SegoeFluentIcons.PC1}"
                                            Content="{Binding [FirstSetup_DaemonUseLocal], Source={x:Static i18n:Lang.Tr}}" />
                        </Button.Content>
                    </Button>
                    <Button HorizontalAlignment="Stretch"
                            Click="UseRemoteDaemon">
                        <Button.Content>
                            <ui:IconAndText IsTabStop="False"
                                            Icon="{x:Static ui:SegoeFluentIcons.Cloud}"
                                            Content="{Binding [FirstSetup_DaemonSkipLocalUseRemote], Source={x:Static i18n:Lang.Tr}}" />
                        </Button.Content>
                    </Button>
                </ikw:SimpleStackPanel>

                <ikw:SimpleStackPanel x:Name="RemoteSetupPanel"
                                      Grid.Row="1"
                                      Spacing="12"
                                      Visibility="Collapsed">
                    <Button x:Name="DaemonActionButton"
                            HorizontalAlignment="Stretch"
                            Click="AddDaemonConnection">
                        <Button.Content>
                            <ui:IconAndText x:Name="DaemonActionButtonContent"
                                            IsTabStop="False"
                                            Icon="{x:Static ui:SegoeFluentIcons.ConnectApp}"
                                            Content="{Binding [ConnectDaemon], Source={x:Static i18n:Lang.Tr}}" />
                        </Button.Content>
                    </Button>

                    <ui:ScrollViewerEx Height="220" Margin="-5,0,-5,0">
                        <ui:ListView x:Name="DaemonListView"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     IsSelectionEnabled="False" />
                    </ui:ScrollViewerEx>
                </ikw:SimpleStackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource StyledBorder}" Height="80">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:HyperlinkButton Content="{Binding [TempSkip], Source={x:Static i18n:Lang.Tr}}" Height="32" Hyperlink.Click="Skip" Grid.Column="0"
                                    HorizontalAlignment="Right" Margin="0,0,20,0" />
                <Button IsEnabled="False" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,40,0" Click="Next"
                        Style="{StaticResource AccentButtonStyle}" x:Name="NextButton" >
                    <Button.Content>
                        <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.PageRight}" Content="{Binding [Continue], Source={x:Static i18n:Lang.Tr}}" />
                    </Button.Content>
                </Button>
            </Grid>
        </Border>
    </Grid>
</ui:Page>
