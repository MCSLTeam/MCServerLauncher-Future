<ui:Page x:Class="MCServerLauncher.WPF.View.Pages.DaemonManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:i18n="clr-namespace:MCServerLauncher.WPF.Modules"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:models="clr-namespace:MCServerLauncher.WPF.ViewModels.Models"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DaemonManagerPage">

    <ui:Page.Resources>
        <DataTemplate DataType="{x:Type models:DaemonCardModel}">
            <Border Style="{StaticResource StyledBorder}" VerticalAlignment="Top" Width="400">
                <Grid Margin="15,15,15,13">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image Height="20" Margin="0,0,0,5" Grid.Column="0" RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Bottom">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SystemType}" Value="Windows">
                                            <Setter Property="Source" Value="{StaticResource WindowsDrawingImage}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SystemType}" Value="Darwin">
                                            <Setter Property="Source" Value="{StaticResource DarwinDrawingImage}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SystemType}" Value="Linux">
                                            <Setter Property="Source" Value="{StaticResource GenericLinuxDrawingImage}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <TextBlock Grid.Column="1" Text="{Binding FriendlyName}" Style="{StaticResource SubtitleTextBlock}"
                                   VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,0,15,5" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource MinititleTextBlock}" Text="{Binding [Daemon_RemoteUri], Source={x:Static i18n:Lang.Tr}}" Grid.Column="0" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,5,5,5" />
                        <TextBlock Style="{StaticResource MinititleTextBlock}" Text="{Binding [Daemon_ConnectionStatus], Source={x:Static i18n:Lang.Tr}}" Grid.Column="0" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,5,0,5" />
                        <TextBlock Style="{StaticResource BodyTextBlock}" Text="{Binding Address}" TextTrimming="CharacterEllipsis" TextWrapping="WrapWithOverflow" Grid.Column="1" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,5,5,5" />
                        <ContentControl Grid.Column="1" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,5,0,5">
                            <ContentControl.Style>
                                <Style TargetType="ContentControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="ok">
                                            <Setter Property="Content">
                                                <Setter.Value>
                                                    <ui:IconAndText Icon="{x:Static ui:SegoeFluentIcons.Accept}" Content="{Binding [Status_OK], Source={x:Static i18n:Lang.Tr}}" IsTabStop="False" VerticalAlignment="Top" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="err">
                                            <Setter Property="Content">
                                                <Setter.Value>
                                                    <ui:IconAndText Icon="{x:Static ui:SegoeFluentIcons.Error}" Content="{Binding [Status_Error], Source={x:Static i18n:Lang.Tr}}" IsTabStop="False" VerticalAlignment="Top" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="ing">
                                            <Setter Property="Content">
                                                <Setter.Value>
                                                    <ui:IconAndText Icon="{x:Static ui:SegoeFluentIcons.HangUp}" Content="{Binding [Connecting], Source={x:Static i18n:Lang.Tr}}" IsTabStop="False" VerticalAlignment="Top" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </Grid>
                    <ui:DropDownButton Grid.Row="2" Margin="20,0,0,0" HorizontalAlignment="Right" ShowChevronArrow="False">
                        <ui:DropDownButton.Content>
                            <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.More}" Content="{Binding [More], Source={x:Static i18n:Lang.Tr}}" />
                        </ui:DropDownButton.Content>
                        <ui:DropDownButton.Flyout>
                            <ui:MenuFlyout Placement="Bottom">
                                <MenuItem Header="{Binding [Edit], Source={x:Static i18n:Lang.Tr}}"
                                          Command="{Binding DataContext.EditDaemonCommand, RelativeSource={RelativeSource AncestorType=ui:Page}}"
                                          CommandParameter="{Binding}">
                                    <MenuItem.Icon>
                                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Edit}" FontSize="16" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{Binding [Delete], Source={x:Static i18n:Lang.Tr}}"
                                          Command="{Binding DataContext.DeleteDaemonCommand, RelativeSource={RelativeSource AncestorType=ui:Page}}"
                                          CommandParameter="{Binding}">
                                    <MenuItem.Icon>
                                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Delete}" FontSize="16" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ui:MenuFlyout>
                        </ui:DropDownButton.Flyout>
                    </ui:DropDownButton>
                </Grid>
            </Border>
        </DataTemplate>
    </ui:Page.Resources>

    <Grid Margin="35,35,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource TitleTextBlock}"
                   Text="{Binding [Main_DaemonManagerNavMenu], Source={x:Static i18n:Lang.Tr}}"
                   VerticalAlignment="Top" HorizontalAlignment="Left" />
        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource MinititleTextBlock}"
                   Text="{Binding [DaemonManagerTip], Source={x:Static i18n:Lang.Tr}}"
                   VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,10,0,0" />
        <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="3" VerticalAlignment="Top" Margin="0,0,40,0"
                Command="{Binding AddConnectionCommand}">
            <Button.Content>
                <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.ConnectApp}" Content="{Binding [ConnectDaemon], Source={x:Static i18n:Lang.Tr}}"/>
            </Button.Content>
        </Button>
        <ui:ScrollViewerEx Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,35,0">
            <ui:GridView ScrollViewer.VerticalScrollBarVisibility="Disabled" IsSelectionEnabled="False" Padding="0,0,0,15"
                         ItemsSource="{Binding Daemons}" />
        </ui:ScrollViewerEx>
    </Grid>
</ui:Page>
