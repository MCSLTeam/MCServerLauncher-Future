<ui:Page x:Class="MCServerLauncher.WPF.View.Pages.InstanceManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:i18n="clr-namespace:MCServerLauncher.WPF.Modules"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:models="clr-namespace:MCServerLauncher.WPF.ViewModels.Models"
      xmlns:ge="clr-namespace:MCServerLauncher.WPF.View.Components.Generic"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="InstanceManagerPage">

    <ui:Page.Resources>
        <DataTemplate DataType="{x:Type models:InstanceCardModel}">
            <Border Style="{StaticResource StyledBorder}" VerticalAlignment="Top" Height="220" Width="400">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <CheckBox Grid.Row="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Top" HorizontalAlignment="Right"
                              Margin="0,15,15,0" MinWidth="0" MinHeight="0" Width="24" Height="24" Padding="0"/>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,15,50,0">
                        <TextBlock Text="{Binding InstanceName}" Style="{StaticResource SubtitleTextBlock}" VerticalAlignment="Center" />
                        <Border CornerRadius="10" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center" x:Name="StatusBadge">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="Running">
                                            <Setter Property="Background" Value="#FF107C10" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Starting">
                                            <Setter Property="Background" Value="#FF0078D4" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Stopping">
                                            <Setter Property="Background" Value="#FFFF8C00" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Stopped">
                                            <Setter Property="Background" Value="#FF999999" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Crashed">
                                            <Setter Property="Background" Value="#FFE81123" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding StatusText}" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                        </Border>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MinititleTextBlock}"
                                   Text="{Binding [InstanceType], StringFormat={}：, Source={x:Static i18n:Lang.Tr}}"
                                   TextWrapping="Wrap" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="20,5,15,5" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource MinititleTextBlock}"
                                   Text="{Binding [Version], StringFormat={}：, Source={x:Static i18n:Lang.Tr}}"
                                   TextWrapping="Wrap" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="20,5,15,5" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding InstanceType}" TextWrapping="Wrap"
                                   FontSize="14" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,5,20,5" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Version}" TextWrapping="Wrap"
                                   FontSize="14" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,5,20,5" />
                    </Grid>

                    <Grid Grid.Row="2" Margin="20,8,20,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58" />
                            <ColumnDefinition Width="116" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource CaptionTextBlock}" Text="{Binding [Daemon_CpuUsage], Source={x:Static i18n:Lang.Tr}}" VerticalAlignment="Center" Margin="0,2,8,2" />
                        <ui:ProgressBar Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding CpuUsageProgress, Mode=OneWay}" VerticalAlignment="Center" Height="6" Margin="0,2,8,2" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource CaptionTextBlock}" Text="{Binding CpuUsageText}" ToolTip="{Binding CpuUsageText}" TextWrapping="NoWrap" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,2,0,2" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource CaptionTextBlock}" Text="{Binding [Daemon_MemoryUsage], Source={x:Static i18n:Lang.Tr}}" VerticalAlignment="Center" Margin="0,2,8,2" />
                        <ui:ProgressBar Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding MemoryUsageProgress, Mode=OneWay}" VerticalAlignment="Center" Height="6" Margin="0,2,8,2" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource CaptionTextBlock}" Text="{Binding MemoryUsageText}" ToolTip="{Binding MemoryUsageText}" TextWrapping="NoWrap" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,2,0,2" />
                    </Grid>

                    <Grid Grid.Row="3" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource AccentButtonStyle}" Margin="20,0,0,20"
                                Command="{Binding DataContext.OpenConsoleCommand, RelativeSource={RelativeSource AncestorType=ui:Page}}"
                                CommandParameter="{Binding}">
                            <Button.Content>
                                <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.View}"
                                                Content="{Binding [View], Source={x:Static i18n:Lang.Tr}}" />
                            </Button.Content>
                        </Button>
                        <ui:DropDownButton Grid.Column="1" Margin="10,0,20,20" ShowChevronArrow="False">
                            <ui:DropDownButton.Content>
                                <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.More}"
                                                Content="{Binding [More], Source={x:Static i18n:Lang.Tr}}" />
                            </ui:DropDownButton.Content>
                            <ui:DropDownButton.Flyout>
                                <ui:MenuFlyout Placement="Bottom">
                                    <MenuItem Header="{Binding [Start], Source={x:Static i18n:Lang.Tr}}"
                                              Command="{Binding StartCommand}"
                                              CommandParameter="{Binding}"
                                              IsEnabled="{Binding CanStart}">
                                        <MenuItem.Icon>
                                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Play}" FontSize="16" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{Binding [Stop], Source={x:Static i18n:Lang.Tr}}"
                                              Command="{Binding StopCommand}"
                                              CommandParameter="{Binding}"
                                              IsEnabled="{Binding CanStop}">
                                        <MenuItem.Icon>
                                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Stop}" FontSize="16" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{Binding [Restart], Source={x:Static i18n:Lang.Tr}}"
                                              Command="{Binding RestartCommand}"
                                              CommandParameter="{Binding}"
                                              IsEnabled="{Binding CanRestart}">
                                        <MenuItem.Icon>
                                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Refresh}" FontSize="16" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="{Binding [Kill], Source={x:Static i18n:Lang.Tr}}"
                                              Command="{Binding KillCommand}"
                                              CommandParameter="{Binding}"
                                              IsEnabled="{Binding CanKill}">
                                        <MenuItem.Icon>
                                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Cancel}" FontSize="16" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="{Binding [Delete], Source={x:Static i18n:Lang.Tr}}"
                                              Command="{Binding DeleteCommand}"
                                              CommandParameter="{Binding}">
                                        <MenuItem.Icon>
                                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Delete}" FontSize="16" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ui:MenuFlyout>
                            </ui:DropDownButton.Flyout>
                        </ui:DropDownButton>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </ui:Page.Resources>

    <Grid Margin="35,35,35,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Style="{StaticResource TitleTextBlock}"
                   Text="{Binding [Main_InstanceManagerNavMenu], Source={x:Static i18n:Lang.Tr}}"
                   VerticalAlignment="Top" HorizontalAlignment="Left"/>
        <TextBlock Grid.Row="1" Style="{StaticResource MinititleTextBlock}"
                   Text="{Binding [InstanceManagerTip], Source={x:Static i18n:Lang.Tr}}"
                   VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,10,0,0"/>

        <!-- 批量操作栏 -->
        <Grid Grid.Row="2" Margin="0,10,0,0" x:Name="BatchOperationBar" Visibility="Collapsed">
            <Border Background="{DynamicResource SystemControlBackgroundAccentBrush}"
                    CornerRadius="4" Padding="15,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="SelectedCountTextBlock"
                                   Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Margin="0,0,10,0" Command="{Binding SelectAllCommand}">
                            <Button.Content>
                                <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.SelectAll}"
                                                Content="{Binding [SelectAll], Source={x:Static i18n:Lang.Tr}}" />
                            </Button.Content>
                        </Button>
                        <Button Margin="0,0,10,0" Command="{Binding BatchStartCommand}">
                            <Button.Content>
                                <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.Play}"
                                                Content="{Binding [Start], Source={x:Static i18n:Lang.Tr}}" />
                            </Button.Content>
                        </Button>
                        <Button Margin="0,0,10,0" Command="{Binding BatchStopCommand}">
                            <Button.Content>
                                <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.Stop}"
                                                Content="{Binding [Stop], Source={x:Static i18n:Lang.Tr}}" />
                            </Button.Content>
                        </Button>
                        <Button Margin="0,0,10,0" Command="{Binding BatchDeleteCommand}">
                            <Button.Content>
                                <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.Delete}"
                                                Content="{Binding [Delete], Source={x:Static i18n:Lang.Tr}}" />
                            </Button.Content>
                        </Button>
                        <Button Command="{Binding CancelSelectionCommand}">
                            <Button.Content>
                                <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.Cancel}"
                                                Content="{Binding [Cancel], Source={x:Static i18n:Lang.Tr}}" />
                            </Button.Content>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="0,10,0,0" x:Name="FilterBar">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0" MinWidth="70" MaxWidth="150" Margin="0,0,10,0" x:Name="DaemonFilter"
                      VerticalAlignment="Top" HorizontalAlignment="Left" SelectionChanged="DaemonFilterChanged"
                      ItemsSource="{Binding DaemonFilterItems}" SelectedIndex="{Binding SelectedDaemonIndex, Mode=TwoWay}"/>
            <ComboBox Grid.Column="1" Width="120" x:Name="RunningStatusFilter"
                      VerticalAlignment="Top" HorizontalAlignment="Left" SelectionChanged="RunningStatusFilterChanged">
                <ComboBoxItem Tag="All" IsSelected="True" Content="{Binding [AllRunningStatus], Source={x:Static i18n:Lang.Tr}}" />
                <ComboBoxItem Tag="Starting" Content="{Binding [Starting], Source={x:Static i18n:Lang.Tr}}" />
                <ComboBoxItem Tag="Running" Content="{Binding [Running], Source={x:Static i18n:Lang.Tr}}" />
                <ComboBoxItem Tag="Stopping" Content="{Binding [Stopping], Source={x:Static i18n:Lang.Tr}}" />
                <ComboBoxItem Tag="Stopped" Content="{Binding [Stopped], Source={x:Static i18n:Lang.Tr}}" />
                <ComboBoxItem Tag="Crashed" Content="{Binding [Crashed], Source={x:Static i18n:Lang.Tr}}" />
            </ComboBox>
            <ui:ToggleSwitch Grid.Column="3" MinWidth="96" Margin="0,0,10,0"
                             OffContent="{Binding [AutoRefresh_Off], Source={x:Static i18n:Lang.Tr}}"
                             OnContent="{Binding [AutoRefresh_On], Source={x:Static i18n:Lang.Tr}}"
                             IsOn="{Binding AutoRefreshEnabled, Mode=TwoWay}" />
            <ComboBox Grid.Column="4" Width="90" Margin="0,0,10,0"
                      ItemsSource="{Binding RefreshIntervalOptions}"
                      DisplayMemberPath="Display"
                      SelectedValuePath="Seconds"
                      SelectedValue="{Binding RefreshIntervalSeconds, Mode=TwoWay}" />
            <TextBox Grid.Column="5" MaxWidth="400" MinWidth="120" Margin="0,0,10,0" x:Name="SearchTextBox" ui:ControlHelper.PlaceholderText="{Binding [Search], Source={x:Static i18n:Lang.Tr}}" />
            <Button Grid.Column="6" Height="32" x:Name="RefreshButton" Command="{Binding RefreshCommand}">
                <Button.Content>
                    <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.Sync}"
                                    Content="{Binding [Refresh], Source={x:Static i18n:Lang.Tr}}" />
                </Button.Content>
            </Button>
        </Grid>
        <ui:ScrollViewerEx Grid.Row="4" Margin="0,15,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <ge:LoadingLayer Grid.Row="0" Grid.Column="0" x:Name="LoadingLayer" />
                <ge:StopTipLayer Grid.Row="0" Grid.Column="0" x:Name="StopTipLayer" Visibility="Collapsed" />
                <ui:GridView Grid.Row="0" Grid.Column="0" x:Name="InstanceCardGrid" ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             IsSelectionEnabled="False" Width="Auto" Padding="0,0,0,15"
                             ItemsSource="{Binding FilteredInstances}" />
            </Grid>
        </ui:ScrollViewerEx>
    </Grid>
</ui:Page>
