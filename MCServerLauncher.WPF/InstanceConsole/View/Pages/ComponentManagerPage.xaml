<Page x:Class="MCServerLauncher.WPF.InstanceConsole.View.Pages.ComponentManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:i18n="clr-namespace:MCServerLauncher.WPF.Modules"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ComponentManagerPage"
      AllowDrop="True"
      Drop="Page_Drop"
      DragOver="Page_DragOver">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Margin="25,15,25,25" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Command="{Binding AddComponentCommand}" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Add}" FontSize="14" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding [ComponentManager_Add], Source={x:Static i18n:Lang.Tr}}" />
                </StackPanel>
            </Button>
            <Button Command="{Binding RefreshCommand}" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Refresh}" FontSize="14" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding [Refresh], Source={x:Static i18n:Lang.Tr}}" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Tab Control -->
        <TabControl Grid.Row="1"
                    FontSize="24"
                    Style="{StaticResource TabControlPivotStyle}"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <!-- Mods Tab -->
            <TabItem Header="{Binding [Mods], Source={x:Static i18n:Lang.Tr}}"
                     IsEnabled="{Binding HasMods}">
                <ui:ListView Margin="0,15,0,0"
                             ItemsSource="{Binding Mods}">
                    <ui:ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="40" Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Enabled/disabled indicator -->
                                <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,10,0"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#4CAF50" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                    <Setter Property="Fill" Value="#9E9E9E" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <!-- Title + Description -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <!-- More Button -->
                                <ui:DropDownButton Grid.Column="2" Height="30" VerticalAlignment="Center">
                                    <ui:DropDownButton.Content>
                                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.More}" FontSize="14" />
                                    </ui:DropDownButton.Content>
                                    <ui:DropDownButton.Flyout>
                                        <ui:MenuFlyout Placement="Bottom">
                                            <MenuItem Command="{Binding DataContext.ToggleEnabledCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                        <Setter Property="Header"
                                                                Value="{Binding [ComponentManager_Disable], Source={x:Static i18n:Lang.Tr}}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                <Setter Property="Header"
                                                                        Value="{Binding [ComponentManager_Enable], Source={x:Static i18n:Lang.Tr}}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Checkbox}" FontSize="16" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{Binding [ComponentManager_Locate], Source={x:Static i18n:Lang.Tr}}"
                                                      Command="{Binding DataContext.LocateCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.OpenFile}" FontSize="16" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="{Binding [Delete], Source={x:Static i18n:Lang.Tr}}"
                                                      Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Delete}" FontSize="16" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ui:MenuFlyout>
                                    </ui:DropDownButton.Flyout>
                                </ui:DropDownButton>
                            </Grid>
                        </DataTemplate>
                    </ui:ListView.ItemTemplate>
                </ui:ListView>
            </TabItem>

            <!-- Plugins Tab -->
            <TabItem Header="{Binding [Plugins], Source={x:Static i18n:Lang.Tr}}"
                     IsEnabled="{Binding HasPlugins}">
                <ui:ListView Margin="0,15,0,0"
                             ItemsSource="{Binding Plugins}">
                    <ui:ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="40" Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,10,0"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#4CAF50" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                    <Setter Property="Fill" Value="#9E9E9E" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <ui:DropDownButton Grid.Column="2" Height="30" VerticalAlignment="Center">
                                    <ui:DropDownButton.Content>
                                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.More}" FontSize="14" />
                                    </ui:DropDownButton.Content>
                                    <ui:DropDownButton.Flyout>
                                        <ui:MenuFlyout Placement="Bottom">
                                            <MenuItem Command="{Binding DataContext.ToggleEnabledCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                        <Setter Property="Header"
                                                                Value="{Binding [ComponentManager_Disable], Source={x:Static i18n:Lang.Tr}}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                <Setter Property="Header"
                                                                        Value="{Binding [ComponentManager_Enable], Source={x:Static i18n:Lang.Tr}}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Checkbox}" FontSize="16" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{Binding [ComponentManager_Locate], Source={x:Static i18n:Lang.Tr}}"
                                                      Command="{Binding DataContext.LocateCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.OpenFile}" FontSize="16" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="{Binding [Delete], Source={x:Static i18n:Lang.Tr}}"
                                                      Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Delete}" FontSize="16" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ui:MenuFlyout>
                                    </ui:DropDownButton.Flyout>
                                </ui:DropDownButton>
                            </Grid>
                        </DataTemplate>
                    </ui:ListView.ItemTemplate>
                </ui:ListView>
            </TabItem>
        </TabControl>

        <!-- Loading overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="2"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
              Background="{DynamicResource AcrylicBackgroundFillColorDefaultBrush}">
            <ui:ProgressRing IsActive="{Binding IsLoading}"
                             Width="48" Height="48"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Page>
