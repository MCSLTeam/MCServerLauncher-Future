<Page x:Class="MCServerLauncher.WPF.InstanceConsole.View.Pages.CommandPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:i18n="clr-namespace:MCServerLauncher.WPF.Modules"
      xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Loaded="Page_Loaded">

    <Grid Margin="25,15,25,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding [ConsoleCommand_FeedbackTip], Source={x:Static i18n:Lang.Tr}}" VerticalAlignment="Center" />
            <Button Height="30" Background="Transparent" BorderThickness="0" Grid.Column="1" Margin="0,0,10,0" Click="ToggleFullscreen">
                <Button.Content>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ui:IconAndText Grid.Column="0" Grid.Row="0" x:Name="OnFullscreenButtonContent" IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.FullScreen}" Content="{Binding [ConsoleCommand_EnterFullScreenConsole], Source={x:Static i18n:Lang.Tr}}" />
                        <ui:IconAndText Grid.Column="0" Grid.Row="0" x:Name="OffFullscreenButtonContent" IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.Stop}" Content="{Binding [ConsoleCommand_ExitFullScreenConsole], Source={x:Static i18n:Lang.Tr}}" />
                    </Grid>
                </Button.Content>
            </Button>
            <ui:DropDownButton Height="30" Background="Transparent" BorderThickness="0" ShowChevronArrow="False"
                               Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Right">
                <ui:DropDownButton.Content>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.More}" FontSize="16" />
                </ui:DropDownButton.Content>
                <ui:DropDownButton.Flyout>
                    <ui:MenuFlyout Placement="Bottom">
                        <MenuItem Header="{Binding [Start], Source={x:Static i18n:Lang.Tr}}" Click="StartInstance_Click">
                            <MenuItem.Icon>
                                <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Play}" FontSize="16" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{Binding [Stop], Source={x:Static i18n:Lang.Tr}}" Click="StopInstance_Click">
                            <MenuItem.Icon>
                                <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.PowerButton}" FontSize="16" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{Binding [Kill], Source={x:Static i18n:Lang.Tr}}" Click="KillInstance_Click">
                            <MenuItem.Icon>
                                <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Cancel}" FontSize="16" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{Binding [Restart], Source={x:Static i18n:Lang.Tr}}" Click="RestartInstance_Click" IsEnabled="False">
                            <MenuItem.Icon>
                                <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Refresh}" FontSize="16" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </ui:MenuFlyout>
                </ui:DropDownButton.Flyout>
            </ui:DropDownButton>
        </Grid>
        <avalonEdit:TextEditor Grid.Row="1" x:Name="ConsoleLogEditor"
                               IsReadOnly="True"
                               Margin="0,15,0,0"
                               FontFamily="Consolas"
                               ShowLineNumbers="False"
                               WordWrap="True"
                               Background="Transparent"
                               Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}">
            <avalonEdit:TextEditor.Options>
                <avalonEdit:TextEditorOptions ShowBoxForControlCharacters="True" EnableTextDragDrop="False" EnableRectangularSelection="True" />
            </avalonEdit:TextEditor.Options>
            <avalonEdit:TextEditor.ContextMenu>
                <ContextMenu>
                    <MenuItem Command="Copy" Header="{Binding [Copy], Source={x:Static i18n:Lang.Tr}}" />
                    <MenuItem Command="SelectAll" Header="{Binding [SelectAll], Source={x:Static i18n:Lang.Tr}}" />
                </ContextMenu>
            </avalonEdit:TextEditor.ContextMenu>
        </avalonEdit:TextEditor>
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" 
                     x:Name="CommandInputTextBox"
                     ui:ControlHelper.PlaceholderText="{Binding [ConsoleCommand_EnterCommandTip], Source={x:Static i18n:Lang.Tr}}" 
                     Height="32" 
                     KeyDown="CommandInputTextBox_KeyDown" />
            <Button Grid.Column="1" Height="32" Margin="10,0,0,0" Click="SendCommand_Click">
                <Button.Content>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Send}" FontSize="16" />
                </Button.Content>
            </Button>
        </Grid>
    </Grid>
</Page>