<Page x:Class="MCServerLauncher.WPF.InstanceConsole.View.Pages.InstanceSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
      xmlns:i18n="clr-namespace:MCServerLauncher.WPF.Modules"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Grid Margin="35,0,35,0">
        <ui:ScrollViewerEx>
            <ikw:SimpleStackPanel Spacing="10">
                <Border Style="{StaticResource StyledBorder}" Margin="0,15,0,0">
                    <Grid Margin="20,15,20,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SubtitleTextBlock}"
                                   Text="{Binding [Console_InstanceSettingsNavMenu], Source={x:Static i18n:Lang.Tr}}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" Style="{StaticResource BodyTextBlock}"
                                   Text="{Binding Settings.WorkingDirectory}" TextWrapping="Wrap" />

                        <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" HorizontalAlignment="Right">
                            <Button Command="{Binding RefreshCommand}" Margin="0,0,0,8">
                                <Button.Content>
                                    <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.Sync}"
                                                    Content="{Binding [Refresh], Source={x:Static i18n:Lang.Tr}}" />
                                </Button.Content>
                            </Button>
                            <Button Style="{StaticResource AccentButtonStyle}" Command="{Binding SaveCommand}" IsEnabled="{Binding Settings.CanEdit}">
                                <Button.Content>
                                    <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.Save}"
                                                    Content="{Binding [Save], Source={x:Static i18n:Lang.Tr}}" />
                                </Button.Content>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource StyledBorder}">
                    <Grid Margin="20,15,20,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource SubtitleTextBlock}"
                                   Text="{Binding [InstanceName], Source={x:Static i18n:Lang.Tr}}" />
                        <TextBox Grid.Row="1" Margin="0,12,0,0" Text="{Binding Settings.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="2" Margin="0,10,0,0" Style="{StaticResource BodyTextBlock}"
                                   Visibility="{Binding Settings.CanEdit, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=False}"
                                   Text="{Binding Settings.EditBlockedReason}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource StyledBorder}">
                    <Grid Margin="20,15,20,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource SubtitleTextBlock}"
                                   Text="{Binding [InstanceType], Source={x:Static i18n:Lang.Tr}}" />
                        <ComboBox Grid.Row="1" Margin="0,12,0,0"
                                  ItemsSource="{Binding Settings.EditableInstanceTypes}"
                                  SelectedItem="{Binding Settings.InstanceType, Mode=TwoWay}" />
                        <TextBlock Grid.Row="2" Margin="0,16,0,0" Style="{StaticResource SubtitleTextBlock}"
                                   Text="{Binding [Version], Source={x:Static i18n:Lang.Tr}}" />
                        <TextBox Grid.Row="3" Margin="0,12,0,0" Text="{Binding Settings.Version, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource StyledBorder}"
                        Visibility="{Binding Settings.SupportsAdvancedEditing, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=False}">
                    <Grid Margin="20,15,20,20">
                        <TextBlock Style="{StaticResource BodyTextBlock}"
                                   Text="{Binding [InstanceSettingsBasicModeNotice], Source={x:Static i18n:Lang.Tr}}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource StyledBorder}"
                        Visibility="{Binding Settings.SupportsAdvancedEditing, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid Margin="20,15,20,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource SubtitleTextBlock}"
                                   Text="{Binding [JavaPath], Source={x:Static i18n:Lang.Tr}}" />
                        <TextBox Grid.Row="1" Margin="0,12,0,0" Text="{Binding Settings.JavaPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="2" Margin="0,16,0,0" Style="{StaticResource SubtitleTextBlock}"
                                   Text="{Binding [JvmArguments], Source={x:Static i18n:Lang.Tr}}" />
                        <TextBox Grid.Row="3" Margin="0,12,0,0" Text="{Binding Settings.ArgumentsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource StyledBorder}"
                        Visibility="{Binding Settings.SupportsAdvancedEditing, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid Margin="20,15,20,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource SubtitleTextBlock}"
                                   Text="{Binding [CorePath], Source={x:Static i18n:Lang.Tr}, FallbackValue=Core}" />
                        <TextBlock Grid.Row="1" Margin="0,10,0,0" Style="{StaticResource BodyTextBlock}"
                                   Text="{Binding Settings.Target}" TextWrapping="Wrap" />
                        <StackPanel Grid.Row="2" Margin="0,14,0,0" Orientation="Horizontal">
                            <Button Command="{Binding SelectReplacementCoreCommand}" Margin="0,0,10,0">
                                <Button.Content>
                                    <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.OpenFile}"
                                                    Content="{Binding [Replace], Source={x:Static i18n:Lang.Tr}, FallbackValue=Replace}" />
                                </Button.Content>
                            </Button>
                            <Button Command="{Binding ClearReplacementCoreCommand}">
                                <Button.Content>
                                    <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.Cancel}"
                                                    Content="{Binding [Cancel], Source={x:Static i18n:Lang.Tr}}" />
                                </Button.Content>
                            </Button>
                        </StackPanel>
                        <TextBlock Grid.Row="3" Margin="0,10,0,0" Style="{StaticResource BodyTextBlock}"
                                   Text="{Binding Settings.ReplacementCorePath}" TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource StyledBorder}"
                        Visibility="{Binding Settings.IsInstallerBased, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid Margin="20,15,20,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource SubtitleTextBlock}"
                                   Text="{Binding [Installer], Source={x:Static i18n:Lang.Tr}}" />
                        <CheckBox Grid.Row="1" Margin="0,12,0,0"
                                  IsChecked="{Binding Settings.ForceRerunInstaller, Mode=TwoWay}"
                                  Content="{Binding [ForceRerunInstaller], Source={x:Static i18n:Lang.Tr}}" />
                        <TextBlock Grid.Row="2" Margin="0,10,0,0" Style="{StaticResource BodyTextBlock}"
                                   Text="{Binding [InstanceSettingsInstallerNotice], Source={x:Static i18n:Lang.Tr}}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Border>
            </ikw:SimpleStackPanel>
        </ui:ScrollViewerEx>
    </Grid>
</Page>
