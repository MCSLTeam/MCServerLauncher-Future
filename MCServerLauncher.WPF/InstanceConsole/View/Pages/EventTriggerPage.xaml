<Page x:Class="MCServerLauncher.WPF.InstanceConsole.View.Pages.EventTriggerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:i18n="clr-namespace:MCServerLauncher.WPF.Modules"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Grid Margin="25,15,25,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Height="35"
                    Margin="0,0,10,0" Click="AddRule_Click">
                <Button.Content>
                    <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.AddTo}" Content="{Binding [Add], Source={x:Static i18n:Lang.Tr}, Mode=OneWay}" />
                </Button.Content>
            </Button>
            <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Height="35" Margin="0,0,10,0" Click="Import_Click">
                <Button.Content>
                    <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.Import}" Content="{Binding [Import], Source={x:Static i18n:Lang.Tr}, Mode=OneWay}" />
                </Button.Content>
            </Button>
            <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Height="35" Margin="0,0,10,0" Click="Export_Click">
                <Button.Content>
                    <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.Export}" Content="{Binding [Export], Source={x:Static i18n:Lang.Tr}, Mode=OneWay}" />
                </Button.Content>
            </Button>
            <Button Grid.Column="3" Background="Transparent" BorderThickness="0" Height="35" Margin="0,0,10,0" Click="Save_Click">
                <Button.Content>
                    <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.Save}" Content="{Binding [Save], Source={x:Static i18n:Lang.Tr}, Mode=OneWay}" />
                </Button.Content>
            </Button>
            <Button Grid.Column="4" Background="Transparent" BorderThickness="0" Height="35" Margin="0,0,10,0" Click="Refresh_Click">
                <Button.Content>
                    <ui:IconAndText IsTabStop="False" Icon="{x:Static ui:SegoeFluentIcons.Refresh}" Content="{Binding [Refresh], Source={x:Static i18n:Lang.Tr}, Mode=OneWay}" />
                </Button.Content>
            </Button>
        </Grid>
        <Grid Grid.Row="1" Margin="0,15,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <ui:InfoBar Grid.Row="0" x:Name="MultiSelectTipBar" IsOpen="True" Severity="Informational" Message="{Binding [MultiSelectTip], Source={x:Static i18n:Lang.Tr}, Mode=OneWay}" Margin="0,0,0,10" IsClosable="True" Closed="MultiSelectTipBar_DoNotShowAgain_Click" />
            <ui:ListView Grid.Row="1" ItemsSource="{Binding Rules}" x:Name="RulesListView" SelectionMode="Extended">
            <ui:ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,15,0">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="16" />
                            <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="12" Margin="0,2,0,0">
                                <Run Text="{Binding Triggers.Count, Mode=OneWay}" /> <Run Text="{Binding [ConsoleCommand_EventTrigger_Trigger], Source={x:Static i18n:Lang.Tr}, Mode=OneWay}" />
                                <Run Text=" | " />
                                <Run Text="{Binding Actions.Count, Mode=OneWay}" /> <Run Text="{Binding [ConsoleCommand_EventTrigger_Event], Source={x:Static i18n:Lang.Tr}, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                            <Button Background="Transparent" BorderThickness="0" Click="CopyRule_Click" Tag="{Binding}" Margin="0,0,5,0" ToolTip="{Binding [Copy], Source={x:Static i18n:Lang.Tr}, Mode=OneWay}">
                                <ui:FontIcon Glyph="&#xE8C8;" />
                            </Button>
                            <Button Background="Transparent" BorderThickness="0" Click="EditRule_Click" Tag="{Binding}" Margin="0,0,5,0" ToolTip="{Binding [Edit], Source={x:Static i18n:Lang.Tr}, Mode=OneWay}">
                                <ui:FontIcon Glyph="&#xE70F;" />
                            </Button>
                            <Button Background="Transparent" BorderThickness="0" Click="DeleteRule_Click" Tag="{Binding}" ToolTip="{Binding [Delete], Source={x:Static i18n:Lang.Tr}, Mode=OneWay}">
                                <ui:FontIcon Glyph="&#xE74D;" />
                            </Button>
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="2" IsOn="{Binding IsEnabled}" VerticalAlignment="Center"
                                         OnContent="{Binding [On], Source={x:Static i18n:Lang.Tr}, Mode=OneWay}"
                                         OffContent="{Binding [Off], Source={x:Static i18n:Lang.Tr}, Mode=OneWay}" />
                    </Grid>
                </DataTemplate>
            </ui:ListView.ItemTemplate>
            </ui:ListView>
        </Grid>
    </Grid>
</Page>
